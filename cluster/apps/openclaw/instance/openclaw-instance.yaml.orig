---
apiVersion: openclaw.rocks/v1alpha1
kind: OpenClawInstance
metadata:
  name: home-ops-openclaw
  namespace: openclaw
spec:
  gateway:
    controlUiOrigins:
      - "https://internal.andrewmccall.com"
      - "https://openclaw-gateway.andrewmccall.com"
  config:
    mergeMode: overwrite
    raw:
      agents:
        defaults:
          model:
            primary: "openrouter/hunter-alpha"
      session:
        scope: per-sender
      gateway:
        http:
          endpoints:
            chatCompletions:
              enabled: true
      diagnostics:
        enabled: true
        otel:
          enabled: true
          endpoint: "http://otel-collector.monitoring.svc:4318"
          protocol: "http/protobuf"
          traces: true
          metrics: true
          logs: true
          serviceName: "openclaw-gateway"
          sampleRate: 0.5
          flushIntervalMs: 5000
      tools:
        media:
          audio:
            models:
              - provider: openai
                model: whisper-1
                baseUrl: "http://whisper-stt.openclaw.svc.cluster.local:9000/v1"
  envFrom:
    - secretRef:
        name: openclaw-api-keys
  env:
    - name: OTEL_EXPORTER_OTLP_ENDPOINT
      value: "http://otel-collector.monitoring.svc:4318"
    - name: OTEL_EXPORTER_OTLP_PROTOCOL
      value: "http/protobuf"
    - name: OTEL_SERVICE_NAME
      value: "openclaw-gateway"
  chromium:
    enabled: true
    persistence:
      enabled: true
      size: 5Gi
    resources:
      requests:
        cpu: 250m
        memory: 512Mi
      limits:
        cpu: 1000m
        memory: 2Gi
  observability:
    metrics:
      enabled: false
  storage:
    persistence:
      enabled: true
      size: 20Gi
